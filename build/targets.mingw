#####################################################################
# Network Device Driver (NDD) Target
#####################################################################

# Build a network device driver module (.ndd file)
# Usage:
#   TARGET = cisco.ndd
#   SOURCES = cisco.cpp
#   OBJECTS = $(SOURCES:.cpp=.o)
#   LIBS = -lnetxms
#   $(eval $(call BUILD_NDDDRIVER,$(TARGET),$(OBJECTS),$(LIBS)))

define BUILD_NDDDRIVER
$(1): $(2)
	@echo "  LD      $$@"
	$(Q)$(CXX) -o $$@ $$^ $(LDFLAGS) -shared $(3)
	@echo "  Built device driver: $(1)"
endef

#####################################################################
# Standard Install Targets (POSIX shell)
#####################################################################

# Install DLL and import library
# Usage: $(call INSTALL_DLL,mylib.dll,mylib.dll.a)
define INSTALL_DLL
install-dll:
	@echo "  INSTALL $(1)"
	@mkdir -p "$(PREFIX)/bin"
	@mkdir -p "$(PREFIX)/lib"
	@cp $(1) "$(PREFIX)/bin/"
	@cp $(2) "$(PREFIX)/lib/"
endef

# Install executable
# Usage: $(call INSTALL_EXE,myapp.exe)
define INSTALL_EXE
install-exe:
	@echo "  INSTALL $(1)"
	@mkdir -p "$(PREFIX)/bin"
	@cp $(1) "$(PREFIX)/bin/"
endef

# Install static library
# Usage: $(call INSTALL_STATIC_LIB,mylib.a)
define INSTALL_STATIC_LIB
install-lib:
	@echo "  INSTALL $(1)"
	@mkdir -p "$(PREFIX)/lib"
	@cp $(1) "$(PREFIX)/lib/"
endef

# Install plugin (subagent, driver, etc.)
# Usage: $(call INSTALL_PLUGIN,mysubagent.nsm,subdir)
define INSTALL_PLUGIN
install-plugin:
	@echo "  INSTALL $(1)"
	@mkdir -p "$(PREFIX)/lib/$(2)"
	@cp $(1) "$(PREFIX)/lib/$(2)/"
endef

# Install headers
# Usage: $(call INSTALL_HEADERS,file1.h file2.h)
define INSTALL_HEADERS
install-headers:
	@echo "  INSTALL headers"
	@mkdir -p "$(PREFIX)/include"
	@for f in $(1); do cp $$f "$(PREFIX)/include/"; done
endef

#####################################################################
# Convenience Macros
#####################################################################

# Simple DLL build (most common case)
# Assumes standard variable names: TARGET, IMPLIB, OBJECTS, LIBS
define SIMPLE_DLL_BUILD
all: $(TARGET)

$(TARGET): $(OBJECTS) $(RC_OBJECT)
	@echo "  LD      $$@"
	$(Q)$(CXX) -o $$@ $$^ $(LDFLAGS) -shared -Wl,--out-implib,$(IMPLIB) $(LIBS)

install: $(TARGET)
	@echo "  INSTALL $(TARGET)"
	@mkdir -p "$(PREFIX)/bin"
	@mkdir -p "$(PREFIX)/lib"
	@cp $(TARGET) "$(PREFIX)/bin/"
	@cp $(IMPLIB) "$(PREFIX)/lib/"

clean:
	rm -f $(OBJECTS) $(RC_OBJECT) $(TARGET) $(IMPLIB)
endef

# Simple executable build (most common case)
# Assumes standard variable names: TARGET, OBJECTS, LIBS
define SIMPLE_EXE_BUILD
all: $(TARGET)

$(TARGET): $(OBJECTS) $(RC_OBJECT)
	@echo "  LD      $$@"
	$(Q)$(CXX) -o $$@ $$^ $(LDFLAGS) $(LIBS)

install: $(TARGET)
	@echo "  INSTALL $(TARGET)"
	@mkdir -p "$(PREFIX)/bin"
	@cp $(TARGET) "$(PREFIX)/bin/"

clean:
	rm -f $(OBJECTS) $(RC_OBJECT) $(TARGET)
endef

#####################################################################
# End of Target Templates
#####################################################################

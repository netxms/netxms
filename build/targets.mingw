#
# Makefile macros for building common target types (DLL, EXE, static lib)
# Note: Uses POSIX shell syntax for MinGW/MSYS2
#

#####################################################################
# Shared Library (DLL) Target
#####################################################################

# Build a DLL with import library
# Usage:
#   TARGET = mylib.dll
#   IMPLIB = mylib.dll.a
#   SOURCES = file1.cpp file2.cpp
#   OBJECTS = $(SOURCES:.cpp=.o)
#   LIBS = -lotherlib
#   $(eval $(call BUILD_DLL,$(TARGET),$(OBJECTS),$(IMPLIB),$(LIBS)))

define BUILD_DLL
$(1): $(2)
	@echo "  LD      $$@"
	$(Q)$(CXX) -o $$@ $$^ $(LDFLAGS) -shared -Wl,--out-implib,$(3) $(4)
	@echo "  Built DLL: $(1)"
endef

#####################################################################
# Executable Target
#####################################################################

# Build an executable
# Usage:
#   TARGET = myapp.exe
#   SOURCES = main.cpp utils.cpp
#   OBJECTS = $(SOURCES:.cpp=.o)
#   LIBS = -lmylib
#   $(eval $(call BUILD_EXE,$(TARGET),$(OBJECTS),$(LIBS)))

define BUILD_EXE
$(1): $(2)
	@echo "  LD      $$@"
	$(Q)$(CXX) -o $$@ $$^ $(LDFLAGS) $(3)
	@echo "  Built executable: $(1)"
endef

#####################################################################
# Static Library Target
#####################################################################

# Build a static library
# Usage:
#   TARGET = mylib.a
#   SOURCES = file1.cpp file2.cpp
#   OBJECTS = $(SOURCES:.cpp=.o)
#   $(eval $(call BUILD_STATIC_LIB,$(TARGET),$(OBJECTS)))

define BUILD_STATIC_LIB
$(1): $(2)
	@echo "  AR      $$@"
	$(Q)$(AR) rcs $$@ $$^
	$(Q)$(RANLIB) $$@
	@echo "  Built static library: $(1)"
endef

#####################################################################
# Agent Subagent (NSM) Target
#####################################################################

# Build an agent subagent module (.nsm file)
# These are DLLs with specific naming and no import library needed
# Usage:
#   TARGET = mysubagent.nsm
#   SOURCES = main.cpp
#   OBJECTS = $(SOURCES:.cpp=.o)
#   LIBS = -lnxagent -lnetxms
#   $(eval $(call BUILD_SUBAGENT,$(TARGET),$(OBJECTS),$(LIBS)))

define BUILD_SUBAGENT
$(1): $(2)
	@echo "  LD      $$@"
	$(Q)$(CXX) -o $$@ $$^ $(LDFLAGS) -shared -Wl,--subsystem,windows $(3)
	@echo "  Built subagent: $(1)"
endef

#####################################################################
# Database Driver (DDR) Target
#####################################################################

# Build a database driver module (.ddr file)
# Similar to subagents but for database drivers
# Usage:
#   TARGET = pgsql.ddr
#   SOURCES = pgsql.cpp
#   OBJECTS = $(SOURCES:.cpp=.o)
#   LIBS = -lnxdb -lpq
#   $(eval $(call BUILD_DBDRIVER,$(TARGET),$(OBJECTS),$(LIBS)))

define BUILD_DBDRIVER
$(1): $(2)
	@echo "  LD      $$@"
	$(Q)$(CXX) -o $$@ $$^ $(LDFLAGS) -shared $(3)
	@echo "  Built database driver: $(1)"
endef


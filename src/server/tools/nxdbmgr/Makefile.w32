#
# Makefile.w32 - nxdbmgr (database manager) for Windows/MinGW
# Part of NetXMS project
#
# The set of sources built on Windows equals *.cpp in this directory (verified
# against nxdbmgr.vcxproj), so the list is taken via wildcard.
#

TOOL = nxdbmgr
SOURCES = $(wildcard *.cpp)

TOOL_CPPFLAGS = -I$(TOPDIR)/src/server/include -I$(TOPDIR)/src/sqlite
TOOL_LIBS = -lnxdbmgr -lnxsrv -lnxsl -lnxdb -lnetxms -lnxjansson -lnxsqlite

include $(TOPDIR)/build/tool-common.mk

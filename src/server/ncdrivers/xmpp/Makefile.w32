#
# Makefile.w32 - xmpp notification channel driver for Windows/MinGW
# Part of NetXMS project
#

DRIVER = xmpp
SOURCES = $(wildcard *.cpp)
# The SDK's libstrophe provides xmpp_stanza_add_child_ex, so skip the in-tree
# compatibility shim (autoconf would define this; the mingw build has no configure).
DRV_CPPFLAGS = -I$(LIBSTROPHE_ROOT)/include -DHAVE_XMPP_STANZA_ADD_CHILD_EX=1
DRV_LIBS = $(STROPHE_LIBS)

include $(TOPDIR)/src/server/ncdrivers/ncdrv-common.mk

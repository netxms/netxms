#
# Makefile.w32 - SQLite database driver for Windows/MinGW
# Part of NetXMS project
#

DRIVER = sqlite
SOURCES = sqlite.cpp

# Uses the bundled SQLite engine (nxsqlite); linked via its in-tree import lib
DRV_CPPFLAGS = -I$(TOPDIR)/src/sqlite
DRV_LIBS = -lnxsqlite

include $(TOPDIR)/src/db/dbdrv/driver-common.mk

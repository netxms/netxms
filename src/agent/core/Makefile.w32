#
# Makefile.w32 - nxagentd (NetXMS monitoring agent) for Windows/MinGW
# Part of NetXMS project
#

# Note: Variables are exported from top-level Makefile.w32

# Target (console executable, emitted into the centralized bin directory)
TARGET = $(BIN_DIR)/nxagentd.exe

# Source files (Windows build)
# Note: subagents are separate DLLs on Windows, so static_subagents.cpp is not built.
#       modbus.cpp / jq usage are enabled via nms_common.h (WITH_MODBUS / HAVE_LIBJQ).
SOURCES = \
	actions.cpp \
	aitools.cpp \
	bkgnd_metrics.cpp \
	certinfo.cpp \
	cng_engine.cpp \
	comm.cpp \
	config.cpp \
	ctrl.cpp \
	datacoll.cpp \
	dbupgrade.cpp \
	dcsnmp.cpp \
	ethernetip.cpp \
	event.cpp \
	exec.cpp \
	extagent.cpp \
	extdp.cpp \
	extension.cpp \
	extension_lifecycle.cpp \
	extension_registry.cpp \
	filemon.cpp \
	hddinfo.cpp \
	localdb.cpp \
	master.cpp \
	metrics.cpp \
	modbus.cpp \
	nproc.cpp \
	nxagentd.cpp \
	package.cpp \
	pe_cert.cpp \
	policy.cpp \
	problems.cpp \
	proxy.cpp \
	push.cpp \
	register.cpp \
	sa.cpp \
	service.cpp \
	session.cpp \
	snmpproxy.cpp \
	snmptrapproxy.cpp \
	subagent.cpp \
	sysinfo.cpp \
	syslog.cpp \
	tcpproxy.cpp \
	tftp.cpp \
	tools.cpp \
	tunnel.cpp \
	watchdog.cpp \
	websvc.cpp \
	wincert.cpp

# cng_engine.cpp uses the Windows CNG API (ncrypt.dll), which is Vista+. Exclude
# it on the XP build so nxagentd does not import ncrypt.dll and can load on XP;
# tunnel.cpp gates its matching CNG code paths.
ifeq ($(WINXP),1)
SOURCES := $(filter-out cng_engine.cpp,$(SOURCES))
endif

# Resource file (embeds version info and the compiled message table MSG00001.bin)
RC_SOURCE = nxagentd.rc

# Message catalog. mc.exe regenerates messages.h + MSG00001.bin from messages.mc
# in one run. Both are generated (gitignored) into the source directory:
# messages.h is #included by agent sources, MSG00001.bin is embedded as an
# RT_MESSAGETABLE resource by nxagentd.rc. This step was previously a Visual
# Studio custom build rule and was lost in the MinGW conversion.
MSG_SOURCE = messages.mc
MSG_HEADER = messages.h
MSG_BIN = MSG00001.bin

# Object files
# Objects go to a per-architecture directory so multiple ARCH builds coexist
OBJDIR = $(OBJ_DIR)/$(subst $(TOPDIR)/,,$(CURDIR))
OBJECTS = $(addprefix $(OBJDIR)/,$(SOURCES:.cpp=.o))
RC_OBJECT = $(OBJDIR)/nxagentd.res.o

# Compiler flags
CXXFLAGS = $(COMMON_CXXFLAGS) \
	-D_CONSOLE

# Linker flags (console executable - no -shared)
LDFLAGS = $(COMMON_LDFLAGS) $(COMMON_LIBDIRS)

# Libraries (in-tree libs found via -L$(LIB_DIR) in COMMON_LIBDIRS)
LIBS = -lnxagent -lnxsde -lnxsnmp -lethernetip -lnxdb -lnetxms -lnxjansson \
	$(JQ_LIBS) \
	$(MODBUS_LIBS) \
	$(CURL_LIBS) \
	$(SSL_LIBS) \
	$(PCRE_LIBS) \
	$(WIN_LIBS) \
	-lmsi -lntdll

# ncrypt.dll (CNG) is Vista+; link it only for non-XP builds (cng_engine.cpp is
# excluded and tunnel.cpp's CNG paths are gated for WINXP).
ifneq ($(WINXP),1)
LIBS += -lncrypt
endif

# Targets
.PHONY: all clean install

all: $(TARGET)

$(TARGET): $(OBJECTS) $(RC_OBJECT)
	@mkdir -p $(BIN_DIR)
	@echo "  LD      $@"
	$(Q)$(CXX) -o $@ $^ $(LDFLAGS) $(LIBS)
	@echo "  Built: $(TARGET)"

$(OBJDIR)/%.o: %.cpp
	@mkdir -p $(dir $@)
	@echo "  CXX     $<"
	$(Q)$(CXX) $(CXXFLAGS) -c $< -o $@

# messages.h drives the mc.exe run; MSG00001.bin is emitted by the same run.
$(MSG_HEADER): $(MSG_SOURCE)
	@echo "  MC      $<"
	$(Q)$(WINMC) -h . -r . $<

$(MSG_BIN): $(MSG_HEADER) ;

# Agent sources #include messages.h; the resource embeds MSG00001.bin.
$(OBJECTS): $(MSG_HEADER)

$(RC_OBJECT): $(RC_SOURCE) $(MSG_BIN)
	@mkdir -p $(dir $@)
	@echo "  RC      $<"
	$(Q)$(WINDRES) -I. -I$(TOPDIR)/include -I$(TOPDIR)/build $< -o $@

clean:
	rm -f $(OBJECTS) $(RC_OBJECT) $(TARGET) $(MSG_HEADER) $(MSG_BIN) messages.rc .depend

install: $(TARGET)
	@echo "  INSTALL $(TARGET)"
	mkdir -p "$(PREFIX)/bin"
	cp $(TARGET) "$(PREFIX)/bin/"

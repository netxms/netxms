#
# Makefile.w32 - mqtt subagent for Windows/MinGW
# Part of NetXMS project
#

SUBAGENT = mqtt
SOURCES = broker.cpp main.cpp topic.cpp
# topic.cpp uses StructuredDataExtractor (libnxsde), whose inline destructor
# calls jv_free, so jq must be linked directly (llvm-mingw resolved it via
# symbol re-export; the mingw GCC/XP toolchain does not).
SA_LIBS = -lnxsde $(JQ_LIBS) $(MOSQUITTO_LIBS)
SA_CPPFLAGS = -I$(MOSQUITTO_ROOT)/include

include $(TOPDIR)/src/agent/subagents/subagent-common.mk

SUBAGENT = netconf
SOURCES = cache.cpp handlers.cpp keys.cpp main.cpp session.cpp sp.cpp
SA_LIBS = -lnxnetconf $(LIBSSH_LIBS)
SA_CPPFLAGS = -I$(LIBSSH_ROOT)/include

include $(TOPDIR)/src/agent/subagents/subagent-common.mk

#
# Makefile.w32 - agent tools dispatcher for Windows/MinGW
# Part of NetXMS project
#
# Recurses into each tool directory. Invoked from the top-level build
# (which exports the shared toolchain/flag variables).
#

TOOLS = \
	nxaevent \
	nxapush \
	nxhwid \
	nxreload \
	nxtftp

.PHONY: all clean install $(TOOLS)

all: $(TOOLS)

$(TOOLS):
	@echo ""
	@echo "==== Building tool $@ ===="
	$(Q)$(MAKE) -C $@ -f Makefile.w32

clean:
	@for dir in $(TOOLS); do \
		if [ -f "$$dir/Makefile.w32" ]; then \
			$(MAKE) -C "$$dir" -f Makefile.w32 clean; \
		fi; \
	done

install:
	@for dir in $(TOOLS); do \
		if [ -f "$$dir/Makefile.w32" ]; then \
			$(MAKE) -C "$$dir" -f Makefile.w32 install; \
		fi; \
	done

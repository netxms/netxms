#
# Makefile.w32 - libnxagent (agent support library) for Windows/MinGW
# Part of NetXMS project
#

# Note: Variables are exported from top-level Makefile.w32

# Target (emitted into the centralized output directories)
TARGET = $(BIN_DIR)/libnxagent.dll
IMPLIB = $(LIB_DIR)/libnxagent.dll.a

# Source files (Windows build includes wtsproc.cpp)
# Note: modbus.cpp compiles to a stub unless WITH_MODBUS is defined
SOURCES = \
	bridge.cpp \
	crl.cpp \
	dfile_info.cpp \
	hwid.cpp \
	main.cpp \
	modbus.cpp \
	optionlist.cpp \
	procexec.cpp \
	registry.cpp \
	smbios.cpp \
	tcpscan.cpp \
	tftp.cpp \
	tools.cpp \
	ua_notification.cpp \
	wtsproc.cpp

# Resource file for version info
RC_SOURCE = $(TOPDIR)/build/netxms-build-tag.rc

# Object files
OBJECTS = $(SOURCES:.cpp=.o)
RC_OBJECT = netxms-build-tag.o

# Compiler flags
CXXFLAGS = $(COMMON_CXXFLAGS) \
	-DLIBNXAGENT_EXPORTS

# Linker flags
LDFLAGS = $(COMMON_LDFLAGS) $(COMMON_LIBDIRS) \
	-shared \
	-Wl,--out-implib,$(IMPLIB)

# Libraries (in-tree libs found via -L$(LIB_DIR) in COMMON_LIBDIRS)
LIBS = -lnetxms -lnxdb \
	$(MODBUS_LIBS) \
	$(CURL_LIBS) \
	$(SSL_LIBS) \
	$(WIN_LIBS)

# Targets
.PHONY: all clean install

all: $(TARGET)

$(TARGET): $(OBJECTS) $(RC_OBJECT)
	@mkdir -p $(BIN_DIR) $(LIB_DIR)
	@echo "  LD      $@"
	$(Q)$(CXX) -o $@ $^ $(LDFLAGS) $(LIBS)
	@echo "  Built: $(TARGET)"

%.o: %.cpp
	@echo "  CXX     $<"
	$(Q)$(CXX) $(CXXFLAGS) -c $< -o $@

$(RC_OBJECT): $(RC_SOURCE)
	@echo "  RC      $<"
	$(Q)$(WINDRES) -I$(TOPDIR)/include -I$(TOPDIR)/build $< -o $@

clean:
	rm -f $(OBJECTS) $(RC_OBJECT) $(TARGET) $(IMPLIB) .depend

install: $(TARGET)
	@echo "  INSTALL $(TARGET)"
	mkdir -p "$(PREFIX)/bin"
	mkdir -p "$(PREFIX)/lib"
	cp $(TARGET) "$(PREFIX)/bin/"
	cp $(IMPLIB) "$(PREFIX)/lib/"

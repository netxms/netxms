#!/bin/sh
#
# Run NetXMS test suite
# Copyright (c) 2020-2022 Raden Solutions
#

if [ "x$NETXMS_HOME" != "x" ]; then
	BINDIR="$NETXMS_HOME/bin"
	DATADIR="$NETXMS_HOME/share/netxms"
	PKGLIBDIR="$NETXMS_HOME/lib/netxms"
	SYSCONFDIR="$NETXMS_HOME/etc"
else
	BINDIR="~BINDIR~"
	DATADIR="~DATADIR~"
	PKGLIBDIR="~PKGLIBDIR~"
	SYSCONFDIR="~SYSCONFDIR~"
fi

echo ""
echo "********** test-libnetxms **********"
$BINDIR/test-libnetxms || exit 1

if [ -x $BINDIR/test-libethernetip ]; then
	echo ""
	echo "********** test-libethernetip **********"
	$BINDIR/test-libethernetip || exit 1
fi

if [ -x $BINDIR/test-libnxsnmp ]; then
	echo ""
	echo "********** test-libnxsnmp **********"
	$BINDIR/test-libnxsnmp || exit 1
fi

if [ -x $BINDIR/test-libnxsl ]; then
	echo ""
	echo "********** test-libnxsl **********"
	$BINDIR/test-libnxsl || exit 1
fi

if [ -x $BINDIR/test-libnxsrv ]; then
	echo ""
	echo "********** test-libnxsrv **********"
	$BINDIR/test-libnxsrv || exit 1
fi

if [ -x $BINDIR/test-ncd-webhook ]; then
	echo ""
	echo "********** test-ncd-webhook **********"
	$BINDIR/test-ncd-webhook || exit 1
fi

if [ -x $BINDIR/test-unit-entsoe ]; then
	echo ""
	echo "********** test-unit-entsoe **********"
	$BINDIR/test-unit-entsoe || exit 1
fi

if [ -x $BINDIR/test-unit-openmeteo ]; then
	echo ""
	echo "********** test-unit-openmeteo **********"
	$BINDIR/test-unit-openmeteo || exit 1
fi

if [ -x $BINDIR/test-unit-linux-cpu-usage-collector ]; then
	echo ""
	echo "********** test-unit-linux-cpu-usage-collector **********"
	$BINDIR/test-unit-linux-cpu-usage-collector || exit 1
fi

exit 0

#
# Makefile.w32 - test-unit-openmeteo (Open-Meteo subagent unit tests) for Windows/MinGW
# Part of NetXMS project
#

# The subagent source under test is compiled into the test binary rather than
# linked from the built subagent. It is located through vpath so its object
# lands in this test's own object directory instead of the subagent's.
# main.cpp exists in both directories; the local copy wins because make only
# consults vpath for prerequisites missing from the current directory.
vpath %.cpp $(TOPDIR)/src/agent/subagents/openmeteo

TOOL = test-unit-openmeteo
SOURCES = main.cpp adapter.cpp
TOOL_CPPFLAGS = -I$(TOPDIR)/tests/include -I$(TOPDIR)/src/agent/subagents/openmeteo
TOOL_LIBS = -lnetxms -lnxjansson $(CURL_LIBS)

include $(TOPDIR)/build/tool-common.mk

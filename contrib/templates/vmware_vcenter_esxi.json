            "snmpPort": 0,
            "snmpVersion": 0,
            "snmpContext": "",
            "instanceDiscoveryMethod": 1,
            "instanceDiscoveryData": "VMware.VMList",
            "instanceFilter": "name = AgentReadParameter($node, \"VMware.VM.Name(\" .. $1 .. \")\");\nreturn [true, $1, (name != null and name != \"\") ? name : $1];",
            "instance": "",
            "instanceRetentionTime": -1,
            "isDisabled": false,
            "unitName": "%",
            "multiplier": 0,
            "allThresholdsRearmEvent": 0,

        {
          "guid": "75c18c9d-90af-4143-b259-aeb52a8d1555",
          "name": "Enable MSSQL subagent",
          "type": "AgentConfig",
          "flags": 0,
          "lastModified": 0,
          "content": "# Enable the MSSQL monitoring subagent.\nSubAgent = mssql\n\n# Define one [mssql/connections/<id>] subsection per monitored SQL Server.\n# The subsection name becomes the connection Id discovered by MSSQL.Connections,\n# which drives the per-connection and per-database instance discovery in this template.\n# Use nxencpasswd to generate an encrypted password and set it via EncryptedPassword.\n#\n#[mssql/connections/sql1]\n#Server = 127.0.0.1\n#Login = monitoring\n#Password = secret\n#Database = master\n",
          "id": 1
        }
      ]

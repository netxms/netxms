            "allThresholdsRearmEvent": 0,
            "transformation": "runningLastChanged = $1;\n\n// Connect to node via SNMP\ntransport = $node.createSNMPTransport();\nif (transport == null) return null;\n\nstartupLastChanged = transport.getValue(\"1.3.6.1.4.1.9.9.43.1.1.2.0\");\nif (startupLastChanged == null) return null;\n\nsysUpTime = transport.getValue(\"1.3.6.1.2.1.1.3.0\");\nif (sysUpTime == null) return null;\n\n\nunsaved = (runningLastChanged > startupLastChanged) && (sysUpTime > 5 * 60 * 100) && (runningLastChanged > 0);\nreturn !unsaved ? \"Yes\" : \"No\";",

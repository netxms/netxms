            "isDisabled": false,
            "unitName": "%",
            "multiplier": 0,
            "allThresholdsRearmEvent": 0,
            "transformation": "// We are originally querying used memory size\nusedMemory = $1;\n\n// Connect to node via SNMP\ntransport = $node.createSNMPTransport();\nif (transport == null) return null;\n\n// Obtain matching free RAM for this pool to calculate usage in %\nfreeMemory = transport.getValue(\"1.3.6.1.4.1.9.9.48.1.1.1.6.\" .. $dci.instance);\nif (freeMemory == null) return null;\n\nreturn format(int64(usedMemory) * 100.0 / (int64(freeMemory) + int64(usedMemory)), 1, 2);",
            "instanceDiscoveryData": "1.3.6.1.4.1.9.9.48.1.1.1.2",
